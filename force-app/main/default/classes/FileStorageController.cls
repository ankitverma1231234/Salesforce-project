public with sharing class FileStorageController {

    @AuraEnabled
    public static List<FileStorageWrapper> getFileStorageRecords(Id recordId) {
        if (recordId == null) {
            throw new AuraHandledException('Record Id is required.');
        }

        String recordIdStr = String.valueOf(recordId);

        List<fra__File_Storage__c> records = [
            SELECT Id,
                   Name,
                   fra__File_Public_Url__c,
                   fra__File_Type__c,
                   fra__File_Size__c,
                   fra__Uploaded_Drive__c,
                   fra__Object_RecordId__c,
                   fra__Related_Object_URL__c,
                   fra__View_File__c,
                   Send_to_Portal__c,
                   Source_Type__c,
                   Description__c,
                   Organization_Name__c,
                   Date_of_Service_Display__c
            FROM fra__File_Storage__c
            WHERE fra__Object_RecordId__c = :recordIdStr
            ORDER BY Name ASC
        ];

        List<FileStorageWrapper> results = new List<FileStorageWrapper>();
        for (fra__File_Storage__c rec : records) {
            FileStorageWrapper w = new FileStorageWrapper();
            w.id = rec.Id;
            w.name = rec.Name;
            w.fileUrl = rec.fra__File_Public_Url__c;
            w.fileType = rec.fra__File_Type__c;
            w.fileSize = rec.fra__File_Size__c;
            w.uploadedDrive = rec.fra__Uploaded_Drive__c;
            w.objectRecordId = rec.fra__Object_RecordId__c;
            w.relatedObjectUrl = rec.fra__Related_Object_URL__c;
            w.viewFile = rec.fra__View_File__c;
            w.sendToPortal = rec.Send_to_Portal__c == true;
            w.sourceType = rec.Source_Type__c;
            w.description = rec.Description__c;
            w.provider = rec.Organization_Name__c;
            w.dateOfService = string.valueof(rec.Date_of_Service_Display__c);
            results.add(w);
        }

        return results;
    }

    @AuraEnabled
    public static void deleteFileStorageRecords(List<Id> recordIds) {
        if (recordIds == null || recordIds.isEmpty()) {
            throw new AuraHandledException('At least one record Id is required.');
        }

        Schema.DescribeSObjectResult objectDescribe = fra__File_Storage__c.SObjectType.getDescribe();
        if (!objectDescribe.isDeletable()) {
            throw new AuraHandledException('You do not have permission to delete file storage records.');
        }

        List<fra__File_Storage__c> files = [
            SELECT Id
            FROM fra__File_Storage__c
            WHERE Id IN :recordIds
            WITH SECURITY_ENFORCED
        ];

        if (files.isEmpty()) {
            throw new AuraHandledException('No matching file storage records were found.');
        }

        delete files;
    }

    public class FileStorageWrapper {
        @AuraEnabled public String id;
        @AuraEnabled public String name;
        @AuraEnabled public String fileUrl;
        @AuraEnabled public String fileType;
        @AuraEnabled public String fileSize;
        @AuraEnabled public String uploadedDrive;
        @AuraEnabled public String objectRecordId;
        @AuraEnabled public String relatedObjectUrl;
        @AuraEnabled public String viewFile;
        @AuraEnabled public Boolean sendToPortal;
        @AuraEnabled public String sourceType;
        @AuraEnabled public String description;
        @AuraEnabled public String provider;
        @AuraEnabled public String dateOfService;
    }
